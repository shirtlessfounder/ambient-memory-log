# Copy this file to the role-specific env file you need:
# - .env.teammate
# - .env.room-mic
# - .env.worker
# - .env.api

DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_SSL_ROOT_CERT=/absolute/path/to/rds-bundle.pem
AWS_REGION=us-east-1
S3_BUCKET=ambient-memory-raw-audio
IMPORT_SPOOL_DIR=./spool/imports
DEEPGRAM_API_KEY=replace-me
PYANNOTE_API_KEY=replace-me
ASSEMBLYAI_API_KEY=replace-me
OPENAI_API_KEY=replace-me
# room-1 still captures/uploads raw 30s chunks; only naming/publication is delayed
ROOM_SPEAKER_ROSTER_PATH=./config/room-speakers.json
ROOM_ASSEMBLY_WINDOW_SECONDS=600
ROOM_ASSEMBLY_IDLE_FLUSH_SECONDS=120
# if a stitched room window has less speech than this, the worker skips it and does not retry it
ROOM_MIN_SPEECH_SECONDS=20
# run-once room second-pass enrichment reads recent canonical room utterances and writes separate inferred rows
SOURCE_ID=desk-a
SOURCE_TYPE=macbook
DEVICE_OWNER=dylan
SPOOL_DIR=./spool
# positive integer (> 0)
CAPTURE_MAX_BACKLOG_FILES=2048
CAPTURE_DEVICE_NAME=Built-in Microphone
# conservative local dead-air filter before upload
SILENCE_FILTER_ENABLED=true
# lower (more negative) values are safer for quiet speech
SILENCE_MAX_VOLUME_DB=-45.0
ACTIVE_START_LOCAL=09:00
ACTIVE_END_LOCAL=00:00
